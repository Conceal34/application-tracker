generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Application {
  id           Int       @id @default(autoincrement())
  company      String
  role         String
  platform     String?
  url          String?
  status       Status    @default(Applied)
  appliedDate  DateTime  @default(now())
  followUpDate DateTime?
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

enum Status {
  Applied
  Viewed
  Interview
  Offer
  Rejected
}
